APP_ENV=local
LOG_LEVEL=INFO

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=20
OPENAI_MAX_RETRIES=1

# AI 응답 생성 방식: mock 또는 openai
# 기본값은 mock입니다.
AI_PROVIDER=mock

FSS_API_KEY=

# 상품 데이터 소스: sample 또는 fss
# 기본값은 sample입니다.
# fss로 설정하면 FSS_API_KEY가 필요합니다.
PRODUCT_DATA_SOURCE=sample

# production 배포 시 comma-separated origin 목록으로 설정한다.
# 예: https://your-frontend-domain.onrender.com
ALLOWED_ORIGINS=
